{
  "title": "SentinelGrid — Platform Overview",
  "uid": "sg-platform-overview",
  "timezone": "browser",
  "refresh": "30s",
  "tags": ["sentinelgrid","platform","prod"],
  "panels": [
    {
      "title": "Events ingested per second (by source org)",
      "type":  "timeseries",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum by (source) (rate(sg_events_ingested_total[1m]))", "legendFormat": "{{source}}" }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "title": "API gateway error rate (5xx)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(http_requests_total{job=\"api-gateway\",code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"api-gateway\"}[5m]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{"color":"green","value":null},{"color":"red","value":0.005}] } } },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "title": "Kafka consumer lag (raw-events → threat-analysis)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(kafka_consumergroup_lag{topic=\"raw-events\"})" }],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "title": "Vault status",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{ "expr": "vault_core_unsealed" }],
      "fieldConfig": { "defaults": { "mappings": [{"options":{"0":{"text":"SEALED","color":"red"},"1":{"text":"UNSEALED","color":"green"}},"type":"value"}] } },
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 }
    },
    {
      "title": "WAF blocked requests / sec",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(rate(aws_wafv2_blocked_requests_sum[5m]))" }],
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 }
    },
    {
      "title": "p99 ingestion latency by service",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by (le, endpoint) (rate(sg_event_latency_seconds_bucket[5m])))", "legendFormat": "{{endpoint}}" }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 }
    }
  ],
  "templating": { "list": [{ "name": "region", "query": "label_values(region)", "type": "query" }] },
  "schemaVersion": 39,
  "version": 1
}
