{
  "name": "sentinelgrid-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "SentinelGrid SOC operator console — Next.js 15 + Tailwind",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "db:seed":    "tsx src/lib/db/seed.ts",
    "db:reset":   "rm -f sentinelgrid.db sentinelgrid.db-* && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "next": "15.5.19",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "lucide-react": "^0.469.0",
    "recharts": "^2.15.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "better-sqlite3": "^11.7.0",
    "geoip-lite": "^1.4.10",
    "ua-parser-js": "^2.0.0",
    "zod": "^3.24.1",
    "bcryptjs": "^2.4.3",
    "node-cron": "^3.0.3",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/geoip-lite": "^1.4.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node-cron": "^3.0.11",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.5.19",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2"
  }
}
